# Copy this file to .env and set real values. Used by Next.js, Prisma, NextAuth, and backend (S3, Redis).
# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/landseed?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Transactional email (Resend)
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="Landseed <onboarding@resend.dev>"

# OpenAI (for AI jobs)
OPENAI_API_KEY="sk-..."

#SerpAPI (for cost of materials)
SERP_API_KEY=""

# AWS S3 (photo uploads)
AWS_S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Redis (queue: virus scanning, AI jobs)
REDIS_URL="redis://localhost:6379"

# ClamAV (virus scanning)
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"
