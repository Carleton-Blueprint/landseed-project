# Copy this file to .env and set real values. Used by Next.js, Prisma, NextAuth, and backend (S3, Redis).
# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/landseed?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Transactional email (Resend)
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
# Use a verified domain in production (not onboarding@resend.dev)
EMAIL_FROM="Landseed <onboarding@resend.dev>"
# Public app URL used in verification and password-reset links
APP_BASE_URL="http://localhost:3000"

# OpenAI (for AI jobs)
OPENAI_API_KEY="sk-..."
GRANT_DISCOVERY_AI_ENABLED=true # Enable AI job for grant discovery (set to "false" to disable), enabled by default
GRANT_DISCOVERY_AI_MODEL="gpt-4o-mini" # Model for grant discovery web search; defaults to gpt-4o-mini
GRANT_DISCOVERY_MOCK_AI=true # Set to "false" for live OpenAI web-search calls
GRANT_DISCOVERY_DEBUG=true # Verbose [DISCOVERY:*] logs in dev server terminal; set "false" to silence
GRANT_DISCOVERY_DEV_MOCK_GET=false # Set to "false" so GET /api/eligibility/[projectId] returns real DB results in dev
BUILDERTREND_MOCK_FAIL=false

#SerpAPI (for cost of materials)
SERP_API_KEY=""

# AWS S3 (photo uploads)
AWS_S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ca-central-1"
# Signed URL expiry for grant document downloads (in seconds, clamped between 60 and 86400)
# GRANT_DOCUMENT_DOWNLOAD_URL_EXPIRY_SECONDS="3600" # set by default to 1 hour, can be overridden here

# Redis (queue: virus scanning, AI jobs)
REDIS_URL="redis://localhost:6379"

# ClamAV (virus scanning)
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"

# Feature flags
# FEATURE_FLAG_MANUAL_REVIEW_AUTO_FLAG=true # set to false by default

# Advisory Team email addresses (comma-separated)
# Temporary solution to acquiring advisory team emails
ADVISORY_TEAM_EMAILS="advisor1@landseed.local,advisor2@landseed.local"

# Audit signing (optional)
# To enable cryptographic signing of audit events, provide a PEM-encoded private key
# in `AUDIT_SIGNING_PRIVATE_KEY` (escape newlines or load from a file in production).
# If provided, the system will sign each new audit event. Verification requires the
# corresponding public key in `AUDIT_SIGNING_PUBLIC_KEY`.
AUDIT_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# PEM public key for verification (optional in dev)
AUDIT_SIGNING_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Human-friendly identifier for the signing key (optional)
AUDIT_SIGNING_KEY_ID="local-key"

# Admin endpoint protection: set a strong random value for `ADMIN_API_KEY` to
# protect the audit verification API. Keep this secret and do not commit it.
ADMIN_API_KEY="replace-with-strong-random-value"

# Local dev: legacy name/email sign-in (no password). Set both to the same value.
DEV_AUTH_BYPASS=true
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
