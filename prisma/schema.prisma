generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                          @id @default(cuid())
  name                          String?
  email                         String?                         @unique
  phone                         String?
  emailVerified                 DateTime?
  passwordHash                  String?
  image                         String?
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  auditEvents                   AuditEvent[]
  grantApplicationStatusHistory GrantApplicationStatusHistory[]
  manualFallbackExports         ManualFallbackExport[]
  notifications                 NotificationDelivery[]
  pricingMatrixAuditLogs        PricingMatrixAuditLog[]
  pricingMatrixVersions         PricingMatrixVersion[]
  projects                      Project[]
  grantedProjectAccess          ProjectAccess[]                 @relation("ProjectAccessGrantedBy")
  projectAccess                 ProjectAccess[]                 @relation("ProjectAccessUser")
  sentCommunications            CommunicationHistory[]          @relation("CommunicationHistorySender")
  receivedCommunications        CommunicationHistory[]          @relation("CommunicationHistoryRecipient")
  accountDeletionRequests       AccountDeletionRequest[]        @relation("AccountDeletionTarget")
  accountDeletionRequestIssuers AccountDeletionRequest[]        @relation("AccountDeletionRequestedBy")
  intakeDraft                   IntakeDraft?
  authEmailTokens               AuthEmailToken[]
  projectStaffNotes             ProjectStaffNote[]
}

model Project {
  id                            String                          @id @default(cuid())
  address                       String
  status                        String                          @default("draft")
  userId                        String
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  draftData                     Json?
  grantDocumentKey              String?
  grantApplicationStatus        GrantApplicationStatus          @default(DRAFT)
  user                          User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectAccess                 ProjectAccess[]
  photos                        Photo[]
  documents                     Document[]
  quotes                        Quote[]
  builderTrendTransfers         BuilderTrendTransfer[]
  manualFallbackExports         ManualFallbackExport[]
  eligibilityAssessments        EligibilityAssessment[]
  grantApplicationStatusHistory GrantApplicationStatusHistory[]
  notifications                 NotificationDelivery[]
  auditEvents                   AuditEvent[]
  manualReviewFlag              ProjectManualReviewFlag?
  communicationHistory          CommunicationHistory[]
  consultationRequest           ConsultationRequest?
  intakeDraft                   IntakeDraft?
  staffNotes                    ProjectStaffNote[]
}

model IntakeDraft {
  id         String   @id @default(cuid())
  userId     String   @unique
  guidedData Json?
  intakeData Json?
  projectId  String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ConsultationRequest {
  id          String   @id @default(cuid())
  projectId   String   @unique
  scheduledAt DateTime
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectStaffNote {
  id           String   @id @default(cuid())
  projectId    String
  authorUserId String
  content      String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([authorUserId])
  @@index([createdAt])
}


model AccountDeletionRequest {
  id                      String                        @id @default(cuid())
  targetUserId            String?
  targetUserEmailSnapshot String
  targetUserNameSnapshot   String?
  requestedByUserId       String?
  requestedByEmailSnapshot String?
  requestedByNameSnapshot  String?
  status                  AccountDeletionRequestStatus  @default(REQUESTED)
  requestedAt             DateTime                      @default(now())
  gracePeriodEndsAt       DateTime
  advanceNoticeDueAt      DateTime
  noticeSentAt            DateTime?
  cancelledAt             DateTime?
  deletedAt               DateTime?
  lastError               String?                       @db.Text
  requestMetadata         Json?
  targetUser              User?                         @relation("AccountDeletionTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  requestedByUser         User?                         @relation("AccountDeletionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  notices                 AccountDeletionNotice[]

  @@index([targetUserId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([requestedAt(sort: Desc)])
  @@index([gracePeriodEndsAt])
  @@index([advanceNoticeDueAt])
}

model AccountDeletionNotice {
  id                      String                      @id @default(cuid())
  accountDeletionRequestId String
  noticeType             AccountDeletionNoticeType
  status                 AccountDeletionNoticeStatus  @default(PENDING)
  recipientEmail         String
  recipientName          String?
  subject                String?
  scheduledFor           DateTime
  sentAt                 DateTime?
  failedAt               DateTime?
  communicationHistoryId String?
  lastError              String?                     @db.Text
  metadata               Json?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  accountDeletionRequest AccountDeletionRequest      @relation(fields: [accountDeletionRequestId], references: [id], onDelete: Cascade)

  @@index([accountDeletionRequestId, noticeType])
  @@index([status])
  @@index([scheduledFor])
  @@index([sentAt])
}

model GrantApplicationStatusHistory {
  id              String                  @id @default(cuid())
  projectId       String
  fromStatus      GrantApplicationStatus?
  toStatus        GrantApplicationStatus
  changedAt       DateTime                @default(now())
  changedByUserId String
  reason          String?
  metadata        Json?
  changedByUser   User                    @relation(fields: [changedByUserId], references: [id])
  project         Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, changedAt(sort: Desc)])
  @@index([changedByUserId, changedAt(sort: Desc)])
}

model Document {
  id               String               @id @default(cuid())
  projectId        String
  fileName         String
  fileSize         Int
  mimeType         String
  s3Key            String
  s3Url            String
  documentType     DocumentType
  label            String?
  virusScanStatus  String               @default("pending")
  reviewStatus     DocumentReviewStatus @default(PENDING)
  reviewNote       String?
  uploadedByUserId String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([documentType])
  @@index([virusScanStatus])
  @@index([reviewStatus])
}

model ProjectAccess {
  id              String            @id @default(cuid())
  projectId       String
  userId          String
  role            ProjectAccessRole @default(VIEWER)
  grantedByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  grantedBy       User?             @relation("ProjectAccessGrantedBy", fields: [grantedByUserId], references: [id])
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User              @relation("ProjectAccessUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([grantedByUserId])
}

model Photo {
  id                String   @id @default(cuid())
  url               String
  virus_scan_status String   @default("pending")
  projectId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Quote {
  id                      String                 @id @default(cuid())
  projectId               String
  subtotal                Decimal                @db.Decimal(10, 2)
  total                   Decimal                @db.Decimal(10, 2)
  generatedAt             DateTime               @default(now())
  pricingMatrixVersionId  String
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  declinedReason          String?
  status                  QuoteStatus            @default(PENDING)
  eligibilityAssessmentId String?
  lastClientActivityAt    DateTime               @default(now())
  estimateMin             Decimal?               @db.Decimal(10, 2)
  estimateMax             Decimal?               @db.Decimal(10, 2)
  refinedEstimate         Json?
  auditEvents             AuditEvent[]
  builderTrendTransfers   BuilderTrendTransfer?
  declineSurvey           DeclineSurveyResponse?
  eligibilityAssessment   EligibilityAssessment? @relation(fields: [eligibilityAssessmentId], references: [id])
  pricingMatrixVersion    PricingMatrixVersion   @relation(fields: [pricingMatrixVersionId], references: [id])
  project                 Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions               QuoteQuestion[]

  @@index([projectId])
  @@index([pricingMatrixVersionId])
  @@index([eligibilityAssessmentId])
}

model DeclineSurveyResponse {
  id                 String   @id @default(cuid())
  quoteId            String   @unique
  primaryReason      String
  subReasons         Json?
  satisfactionRating Int?
  additionalComments String?
  wouldReconsider    Boolean  @default(false)
  createdAt          DateTime @default(now())
  quote              Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([primaryReason])
  @@index([createdAt])
}

model BuilderTrendTransfer {
  id                String                     @id @default(cuid())
  projectId         String
  quoteId           String                     @unique
  status            BuilderTrendTransferStatus @default(PENDING)
  payload           Json?
  attempts          Int                        @default(0)
  externalReference String?
  lastError         String?
  requestedAt       DateTime                   @default(now())
  sentAt            DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  project           Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quote             Quote                      @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model QuoteQuestion {
  id            String           @id @default(cuid())
  quoteId       String
  category      QuestionCategory
  subject       String
  message       String
  status        QuestionStatus   @default(OPEN)
  response      String?
  respondedAt   DateTime?
  askedByUserId String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  quote         Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([status])
  @@index([askedByUserId])
  @@index([quoteId, status])
}

model AuditEvent {
  id               String                @id @default(cuid())
  category         AuditEventCategory
  action           String
  outcome          AuditEventOutcome
  sensitivityLevel AuditSensitivityLevel @default(CONFIDENTIAL)
  actorUserId      String?
  projectId        String?
  quoteId          String?
  resourceType     String
  resourceId       String?
  reason           String?
  description      String?
  beforeState      Json?
  afterState       Json?
  metadata         Json?
  // Tamper-evident chain fields)
  eventHash        String?               @db.Text
  prevHash         String?               @db.Text
  signature        String?               @db.Text
  signedAt         DateTime?
  signedBy         String?

  ipAddress        String?
  userAgent        String?
  createdAt        DateTime              @default(now())
  actorUser        User?                 @relation(fields: [actorUserId], references: [id])
  project          Project?              @relation(fields: [projectId], references: [id])
  quote            Quote?                @relation(fields: [quoteId], references: [id])

  @@index([createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([outcome, createdAt])
  @@index([sensitivityLevel, createdAt])
  @@index([actorUserId, createdAt])
  @@index([projectId, createdAt])
  @@index([quoteId, createdAt])
  @@index([resourceType, resourceId])
}

model PricingMatrixVersion {
  id              String                  @id @default(cuid())
  versionNumber   Int                     @unique
  data            Json
  createdAt       DateTime                @default(now())
  createdByUserId String
  isActive        Boolean                 @default(false)
  auditLogs       PricingMatrixAuditLog[]
  createdBy       User                    @relation(fields: [createdByUserId], references: [id])
  quotes          Quote[]

  @@index([versionNumber])
  @@index([isActive])
}

model EligibilityAssessment {
  id                        String              @id @default(cuid())
  projectId                 String
  overallDecision           EligibilityDecision
  programDecisions          Json
  reasonCodes               Json
  missingRequirements       Json
  isLatest                  Boolean             @default(true)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  discoveredGrants          Json?
  discoveryMetadata         Json?
  discoveryProvider         String?
  discoveryEngineVersion    String?
  discoveryPromptVersion    String?
  discoveryScoringVersion   String?
  discoveryModelVersion     String?
  discoverySourceSnapshotId String?
  project                   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotes                    Quote[]

  @@index([projectId])
  @@index([projectId, isLatest])
  @@index([createdAt])
}

model PricingMatrixAuditLog {
  id              String               @id @default(cuid())
  versionId       String
  changedByUserId String
  changedAt       DateTime             @default(now())
  changeSummary   String?
  beforeState     Json?
  afterState      Json?
  changedBy       User                 @relation(fields: [changedByUserId], references: [id])
  version         PricingMatrixVersion @relation(fields: [versionId], references: [id])

  @@index([versionId])
  @@index([changedAt])
}

model NotificationDelivery {
  id                String                     @id @default(cuid())
  eventType         NotificationEventType
  status            NotificationDeliveryStatus @default(PENDING)
  recipientEmail    String
  subject           String
  templateName      String
  idempotencyKey    String                     @unique
  provider          String?
  providerMessageId String?
  attempts          Int                        @default(0)
  lastError         String?
  payload           Json?
  sentAt            DateTime?
  userId            String?
  projectId         String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  project           Project?                   @relation(fields: [projectId], references: [id])
  user              User?                      @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([status])
  @@index([projectId])
  @@index([userId])
}

model ManualFallbackExport {
  id                String                     @id
  projectId         String
  requestedByUserId String
  requestedByEmail  String?
  requestedByName   String?
  status            ManualFallbackExportStatus @default(PENDING)
  s3Key             String?
  fileName          String?
  retentionDays     Int
  maxSizeBytes      Int?
  lastError         String?                    @db.Text
  requestedAt       DateTime                   @default(now())
  readyAt           DateTime?
  expiresAt         DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  project           Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedByUser   User                       @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@index([expiresAt])
  @@index([projectId])
  @@index([requestedByUserId])
  @@index([status])
}

model ProjectManualReviewFlag {
  id                                    String                        @id @default(cuid())
  projectId                             String                        @unique
  reason                                ProjectManualReviewReasonCode
  isActive                              Boolean                       @default(true)
  lastEvaluatedAt                       DateTime                      @default(now())
  lastEvaluationEligibilityAssessmentId String?
  description                           String?                       @db.Text
  createdAt                             DateTime                      @default(now())
  updatedAt                             DateTime                      @updatedAt
  project                               Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isActive])
  @@index([reason])
  @@index([createdAt])
}

model CommunicationHistory {
  id                   String                    @id @default(cuid())
  projectId            String
  project              Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  communicationType    CommunicationType
  category             CommunicationCategory
  
  recipientId          String?
  recipient            User?                     @relation("CommunicationHistoryRecipient", fields: [recipientId], references: [id])
  senderId             String?
  sender               User?                     @relation("CommunicationHistorySender", fields: [senderId], references: [id])
  recipientEmail       String
  
  subject              String
  contentSummary       String
  
  linkedResourceType   String?
  linkedResourceId     String?
  
  status               CommunicationStatus
  
  metadata             Json?
  
  sentAt               DateTime                  @default(now())
  deliveredAt          DateTime?
  readAt               DateTime?
  createdAt            DateTime                  @default(now())

  @@index([projectId, sentAt(sort: Desc)])
  @@index([recipientId, projectId])
  @@index([category])
  @@index([communicationType])
  @@index([status])
}

// ——— Enums ———

enum GrantApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  PROOF_OF_INCOME
  MEDICAL_DOCUMENTATION
  PROPERTY_OWNERSHIP
  INSURANCE_DOCUMENT
  GOVERNMENT_ID
  TAX_ASSESSMENT
  DISABILITY_CERTIFICATE
  OTHER
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectAccessRole {
  OWNER
  EDITOR
  VIEWER
}

enum BuilderTrendTransferStatus {
  PENDING
  RETRYING
  SENT
  FAILED
}

enum QuestionCategory {
  PRICING
  SCOPE
  TIMELINE
  MATERIALS
  GRANT_ELIGIBILITY
  MODIFICATION_REQUEST
  GENERAL
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum AuditEventCategory {
  MANUAL_CHANGE
  SENSITIVE_ACCESS
}

enum AuditEventOutcome {
  SUCCESS
  DENIED
  FAILURE
}

enum AuditSensitivityLevel {
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum EligibilityDecision {
  ELIGIBLE
  INELIGIBLE
  NEEDS_MORE_INFO
  MANUAL_REVIEW
}

enum AuthEmailTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model AuthEmailToken {
  id        String                @id @default(cuid())
  userId    String
  purpose   AuthEmailTokenPurpose
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([tokenHash])
}

enum NotificationEventType {
  SUBMISSION_RECEIPT
  ESTIMATE_READY
  ESTIMATE_EXPIRED
  ESTIMATE_REACTIVATED
  MANUAL_FALLBACK_EXPORT_READY
  QUESTION_SUBMITTED_FOR_ADVISORY_TEAM
  FILE_MALWARE_DETECTED
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum AccountDeletionRequestStatus {
  REQUESTED
  IN_GRACE_PERIOD
  CANCELLED
  READY_FOR_DELETION
  DELETED
}

enum AccountDeletionNoticeType {
  ADVANCE_NOTICE
  FINAL_NOTICE
}

enum AccountDeletionNoticeStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum NotificationDeliveryStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum ManualFallbackExportStatus {
  PENDING
  READY
  FAILED
}

enum ProjectManualReviewReasonCode {
  LOW_CONFIDENCE
  HIGH_COMPLEXITY
  BOTH
}

enum CommunicationType {
  EMAIL
  SMS
  IN_APP_NOTIFICATION
  SYSTEM_MESSAGE
}

enum CommunicationCategory {
  ESTIMATE
  QUESTION
  DOCUMENT
  GRANT_STATUS
  SUBMISSION_RECEIPT
  SURVEY
  SYSTEM_ALERT
  OTHER
}

enum CommunicationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
  BOUNCED
}
