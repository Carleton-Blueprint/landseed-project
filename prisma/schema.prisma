// Prisma schema: PostgreSQL models for the app.
// User: app user (name, email, phone); Account/Session/VerificationToken: NextAuth.
// Project: address + status, owned by User. Photo: url + virus_scan_status, belongs to Project.
// Run `npx prisma generate` after changes; use `db push` or `migrate dev` to apply to DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  phone                  String?
  emailVerified          DateTime?
  image                  String?
  accounts               Account[]
  sessions               Session[]
  projects               Project[]
  projectAccess          ProjectAccess[]         @relation("ProjectAccessUser")
  grantedProjectAccess   ProjectAccess[]         @relation("ProjectAccessGrantedBy")
  pricingMatrixVersions  PricingMatrixVersion[]
  grantRulesVersions     GrantRulesVersion[]
  pricingMatrixAuditLogs PricingMatrixAuditLog[]
  grantRulesAuditLogs    GrantRulesAuditLog[]
  notifications          NotificationDelivery[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @unique
  token      String   @unique
  expires    DateTime
}

model Project {
  id        String   @id @default(cuid())
  address   String
  status    String   @default("draft")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectAccess ProjectAccess[]
  photos    Photo[]
  quotes    Quote[]
  notifications NotificationDelivery[]
  draftData        Json?
  grantDocumentKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectAccessRole {
  OWNER
  EDITOR
  VIEWER
}

model ProjectAccess {
  id              String            @id @default(cuid())
  projectId       String
  userId          String
  role            ProjectAccessRole @default(VIEWER)
  grantedByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?   @relation("ProjectAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([grantedByUserId])
}

model Photo {
  id                String   @id @default(cuid())
  url               String
  virus_scan_status String   @default("pending")
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Quote {
  id          String   @id @default(cuid())
  projectId   String
  subtotal    Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  generatedAt DateTime @default(now())

  pricingMatrixVersionId String
  grantRulesVersionId    String

  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pricingMatrixVersion PricingMatrixVersion @relation(fields: [pricingMatrixVersionId], references: [id])
  grantRulesVersion    GrantRulesVersion    @relation(fields: [grantRulesVersionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status         QuoteStatus @default(PENDING)
  declinedReason String?     @db.Text

  @@index([projectId])
  @@index([pricingMatrixVersionId])
  @@index([grantRulesVersionId])
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model PricingMatrixVersion {
  id              String   @id @default(cuid())
  versionNumber   Int      @unique
  data            Json
  createdAt       DateTime @default(now())
  createdByUserId String
  isActive        Boolean  @default(false)

  createdBy User                    @relation(fields: [createdByUserId], references: [id])
  quotes    Quote[]
  auditLogs PricingMatrixAuditLog[]

  @@index([versionNumber])
  @@index([isActive])
}

model GrantRulesVersion {
  id              String   @id @default(cuid())
  versionNumber   Int      @unique
  rules           Json
  createdAt       DateTime @default(now())
  createdByUserId String
  isActive        Boolean  @default(false)

  createdBy User                 @relation(fields: [createdByUserId], references: [id])
  quotes    Quote[]
  auditLogs GrantRulesAuditLog[]

  @@index([versionNumber])
  @@index([isActive])
}

model PricingMatrixAuditLog {
  id              String   @id @default(cuid())
  versionId       String
  changedByUserId String
  changedAt       DateTime @default(now())
  changeSummary   String?  @db.Text
  beforeState     Json?
  afterState      Json?

  version   PricingMatrixVersion @relation(fields: [versionId], references: [id])
  changedBy User                 @relation(fields: [changedByUserId], references: [id])

  @@index([versionId])
  @@index([changedAt])
}

model GrantRulesAuditLog {
  id              String   @id @default(cuid())
  versionId       String
  changedByUserId String
  changedAt       DateTime @default(now())
  changeSummary   String?  @db.Text
  beforeState     Json?
  afterState      Json?

  version   GrantRulesVersion @relation(fields: [versionId], references: [id])
  changedBy User              @relation(fields: [changedByUserId], references: [id])

  @@index([versionId])
  @@index([changedAt])
}

enum NotificationEventType {
  SUBMISSION_RECEIPT
  ESTIMATE_READY
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model NotificationDelivery {
  id                String                     @id @default(cuid())
  eventType         NotificationEventType
  status            NotificationDeliveryStatus @default(PENDING)
  recipientEmail    String
  subject           String
  templateName      String
  idempotencyKey    String                     @unique
  provider          String?
  providerMessageId String?
  attempts          Int                        @default(0)
  lastError         String?
  payload           Json?
  sentAt            DateTime?
  userId            String?
  projectId         String?
  user              User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  project           Project?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([eventType])
  @@index([status])
  @@index([projectId])
  @@index([userId])
}
