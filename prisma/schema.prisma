// Prisma schema: PostgreSQL models for the app.
// User: app user (name, email, phone); Account/Session/VerificationToken: NextAuth.
// Project: address + status, owned by User. Photo: url + virus_scan_status, belongs to Project.
// Run `npx prisma generate` after changes; use `db push` or `migrate dev` to apply to DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  phone                  String?
  emailVerified          DateTime?
  image                  String?
  accounts               Account[]
  sessions               Session[]
  projects               Project[]
  projectAccess          ProjectAccess[]         @relation("ProjectAccessUser")
  grantedProjectAccess   ProjectAccess[]         @relation("ProjectAccessGrantedBy")
  pricingMatrixVersions  PricingMatrixVersion[]
  pricingMatrixAuditLogs PricingMatrixAuditLog[]
  grantApplicationStatusHistory GrantApplicationStatusHistory[]
  notifications          NotificationDelivery[]
  auditEvents            AuditEvent[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @unique
  token      String   @unique
  expires    DateTime
}

model Project {
  id        String   @id @default(cuid())
  address   String
  status    String   @default("draft")
  grantApplicationStatus GrantApplicationStatus @default(DRAFT)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectAccess ProjectAccess[]
  photos    Photo[]
  documents Document[]
  quotes    Quote[]
  builderTrendTransfers BuilderTrendTransfer[]
  eligibilityAssessments EligibilityAssessment[]
  grantApplicationStatusHistory GrantApplicationStatusHistory[]
  notifications NotificationDelivery[]
  auditEvents   AuditEvent[]
  draftData        Json?
  grantDocumentKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GrantApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model GrantApplicationStatusHistory {
  id              String                 @id @default(cuid())
  projectId       String
  fromStatus      GrantApplicationStatus?
  toStatus        GrantApplicationStatus
  changedAt       DateTime               @default(now())
  changedByUserId String
  reason          String?                @db.Text
  metadata        Json?

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changedByUser User    @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([projectId, changedAt(sort: Desc)])
  @@index([changedByUserId, changedAt(sort: Desc)])
}

enum DocumentType {
  PROOF_OF_INCOME
  MEDICAL_DOCUMENTATION
  PROPERTY_OWNERSHIP
  INSURANCE_DOCUMENT
  GOVERNMENT_ID
  TAX_ASSESSMENT
  DISABILITY_CERTIFICATE
  OTHER
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Document {
  id                String               @id @default(cuid())
  projectId         String
  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName          String
  fileSize          Int
  mimeType          String
  s3Key             String
  s3Url             String
  documentType      DocumentType
  label             String?
  virusScanStatus   String               @default("pending")
  reviewStatus      DocumentReviewStatus @default(PENDING)
  reviewNote        String?              @db.Text
  uploadedByUserId  String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([projectId])
  @@index([documentType])
  @@index([virusScanStatus])
  @@index([reviewStatus])
}

enum ProjectAccessRole {
  OWNER
  EDITOR
  VIEWER
}

model ProjectAccess {
  id              String            @id @default(cuid())
  projectId       String
  userId          String
  role            ProjectAccessRole @default(VIEWER)
  grantedByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?   @relation("ProjectAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([grantedByUserId])
}

model Photo {
  id                String   @id @default(cuid())
  url               String
  virus_scan_status String   @default("pending")
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Quote {
  id          String   @id @default(cuid())
  projectId   String
  subtotal    Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  estimateMin Decimal? @db.Decimal(10, 2)
  estimateMax Decimal? @db.Decimal(10, 2)
  refinedEstimate Json?
  generatedAt DateTime @default(now())
  lastClientActivityAt DateTime @default(now())

  pricingMatrixVersionId String
  eligibilityAssessmentId String?

  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pricingMatrixVersion  PricingMatrixVersion  @relation(fields: [pricingMatrixVersionId], references: [id])
  eligibilityAssessment EligibilityAssessment? @relation(fields: [eligibilityAssessmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status         QuoteStatus @default(PENDING)
  declinedReason String?     @db.Text
  auditEvents    AuditEvent[]
  questions      QuoteQuestion[]
  builderTrendTransfers BuilderTrendTransfer[]

  declineSurvey  DeclineSurveyResponse?

  @@index([projectId])
  @@index([pricingMatrixVersionId])
  @@index([eligibilityAssessmentId])
}

model DeclineSurveyResponse {
  id              String   @id @default(cuid())
  quoteId         String   @unique
  primaryReason   String
  subReasons      Json?
  satisfactionRating Int?
  additionalComments String? @db.Text
  wouldReconsider Boolean  @default(false)
  createdAt       DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([primaryReason])
  @@index([createdAt])
}

enum BuilderTrendTransferStatus {
  PENDING
  SENT
  FAILED
}

model BuilderTrendTransfer {
  id                String                    @id @default(cuid())
  projectId         String
  quoteId           String
  status            BuilderTrendTransferStatus @default(PENDING)
  payload           Json?
  attempts          Int                       @default(0)
  externalReference String?
  lastError         String?                   @db.Text
  requestedAt       DateTime                  @default(now())
  sentAt            DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId])
  @@index([projectId])
  @@index([status])
}

enum QuestionCategory {
  PRICING
  SCOPE
  TIMELINE
  MATERIALS
  GRANT_ELIGIBILITY
  MODIFICATION_REQUEST
  GENERAL
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

model QuoteQuestion {
  id            String           @id @default(cuid())
  quoteId       String
  quote         Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  category      QuestionCategory
  subject       String
  message       String           @db.Text
  status        QuestionStatus   @default(OPEN)
  response      String?          @db.Text
  respondedAt   DateTime?
  askedByUserId String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([quoteId])
  @@index([status])
  @@index([askedByUserId])
  @@index([quoteId, status])
}

enum AuditEventCategory {
  MANUAL_CHANGE
  SENSITIVE_ACCESS
}

enum AuditEventOutcome {
  SUCCESS
  DENIED
  FAILURE
}

enum AuditSensitivityLevel {
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

model AuditEvent {
  id               String                @id @default(cuid())
  category         AuditEventCategory
  action           String
  outcome          AuditEventOutcome
  sensitivityLevel AuditSensitivityLevel @default(CONFIDENTIAL)

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  resourceType String
  resourceId   String?

  reason      String? @db.Text
  description String? @db.Text

  beforeState Json?
  afterState  Json?
  metadata    Json?

  ipAddress String?
  userAgent String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([outcome, createdAt])
  @@index([sensitivityLevel, createdAt])
  @@index([actorUserId, createdAt])
  @@index([projectId, createdAt])
  @@index([quoteId, createdAt])
  @@index([resourceType, resourceId])
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model PricingMatrixVersion {
  id              String   @id @default(cuid())
  versionNumber   Int      @unique
  data            Json
  createdAt       DateTime @default(now())
  createdByUserId String
  isActive        Boolean  @default(false)

  createdBy User                    @relation(fields: [createdByUserId], references: [id])
  quotes    Quote[]
  auditLogs PricingMatrixAuditLog[]

  @@index([versionNumber])
  @@index([isActive])
}

enum EligibilityDecision {
  ELIGIBLE
  INELIGIBLE
  NEEDS_MORE_INFO
  MANUAL_REVIEW
}

model EligibilityAssessment {
  id                  String              @id @default(cuid())
  projectId           String
  overallDecision     EligibilityDecision
  programDecisions    Json
  reasonCodes         Json
  missingRequirements Json
  discoveredGrants    Json?
  discoveryMetadata   Json?
  discoveryProvider   String?
  discoveryEngineVersion String?
  discoveryPromptVersion String?
  discoveryScoringVersion String?
  discoveryModelVersion String?
  discoverySourceSnapshotId String?
  isLatest            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotes            Quote[]

  @@index([projectId])
  @@index([projectId, isLatest])
  @@index([createdAt])
}

model PricingMatrixAuditLog {
  id              String   @id @default(cuid())
  versionId       String
  changedByUserId String
  changedAt       DateTime @default(now())
  changeSummary   String?  @db.Text
  beforeState     Json?
  afterState      Json?

  version   PricingMatrixVersion @relation(fields: [versionId], references: [id])
  changedBy User                 @relation(fields: [changedByUserId], references: [id])

  @@index([versionId])
  @@index([changedAt])
}

enum NotificationEventType {
  SUBMISSION_RECEIPT
  ESTIMATE_READY
  ESTIMATE_EXPIRED
  ESTIMATE_REACTIVATED
  QUESTION_SUBMITTED_FOR_ADVISORY_TEAM
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model NotificationDelivery {
  id                String                     @id @default(cuid())
  eventType         NotificationEventType
  status            NotificationDeliveryStatus @default(PENDING)
  recipientEmail    String
  subject           String
  templateName      String
  idempotencyKey    String                     @unique
  provider          String?
  providerMessageId String?
  attempts          Int                        @default(0)
  lastError         String?
  payload           Json?
  sentAt            DateTime?
  userId            String?
  projectId         String?
  user              User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  project           Project?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([eventType])
  @@index([status])
  @@index([projectId])
  @@index([userId])
}
